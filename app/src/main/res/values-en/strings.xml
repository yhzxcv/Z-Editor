    <string name="about_screen_title">Introduction</string>
    <string name="about_screen_name">Z-Editor</string>
    <string name="about_screen_intro">PVZ2C Visual Level Editor</string>
    <string name="about_screen_introduction_text">Editor is a visual level editing  tool designed for Plants vs. Zombies 2 Chinese. It aims to simplify editing level JSON files with an intuitive interface.</string>
    <string name="about_screen_introduction_title">Introduction</string>
    <string name="about_screen_feature_title">Features</string>
    <string name="about_screen_feature_text1">Modular editing: Manage level modules and events.</string>
    <string name="about_screen_feature_text2">Multi-mode: I, Zombie, Vase Breaker, Last Stand, Zomboss battle.</string>
    <string name="about_screen_feature_text3">Custom zombies: Inject and edit custom zombie properties.</string>
    <string name="about_screen_feature_text4">Validation: Detect missing modules and broken references.</string>
    <string name="about_screen_feature_text5">Preview Resources: Include icons for plants, zombies and griditems.</string>
    <string name="about_screen_usage_title">Usage</string>
    <string name="about_screen_usage_text1">1. Folder: Tap folder icon to choose level JSON directory.</string>
    <string name="about_screen_usage_text2">2. Open/Create: Tap a level to edit or use+ to create from template.</string>
    <string name="about_screen_usage_text3">3. Modules: Add modules in the editor.</string>
    <string name="about_screen_usage_text4">4. Save: Tap save to write back to the JSON fille.</string>
    <string name="about_screen_usage_text5">QQ group: 562251204</string>
